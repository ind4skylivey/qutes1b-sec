# Qutebrowser configuration - .gitignore

# Autoconfig file (generated by qutebrowser)
autoconfig.yml

# Sessions
sessions/

# History
history
history-json
hst/

# Downloads
downloads/

# Data
data/

# Cache
cache/

# Runtime
runtime/

# Quickmarks (if version controlling causes issues)
quickmarks

# Local configuration overrides
local-config.py

# Python cache
__pycache__/
*.py[cod]
*$py.class

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Backup and working files (temporary)
*.backup
config.py.backup
config.py.working
